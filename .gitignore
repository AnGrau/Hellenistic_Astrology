# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Fichiers de données Swiss Ephemeris (téléchargés par scripts/fetch_ephemeris.py)
data/ephe/*.se1

# Données personnelles des cas de test (dates/lieux de naissance d'Anthony et Liam) :
# jamais poussées sur GitHub. Le code des tests reste versionné.
/tests/fixtures/
/References/
/output/

# Zips locaux pour l'import manuel des skills dans Claude Desktop (voir
# README.md, section "Skills dans Claude Desktop") : artefacts d'upload,
# régénérés à la main quand un SKILL.md change, jamais synchronisés
# automatiquement — pas la peine de les versionner.
.claude/skills/*.zip
